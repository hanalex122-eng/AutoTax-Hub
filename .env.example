# ══════════════════════════════════════════════════════
#  AutoTax-HUB v3 — Production Environment
#  cp .env.example .env  →  fill in values
# ══════════════════════════════════════════════════════

# Database
DATABASE_URL=postgresql://autotax:STRONG_PASSWORD@localhost:5432/autotaxhub

# JWT — python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_THIS

# App
APP_ENV=production
ALLOWED_ORIGINS=https://yourdomain.com

# Email (set MAIL_ENABLED=true in production)
MAIL_ENABLED=false
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=app-password-here
MAIL_FROM=noreply@autotaxhub.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# Frontend URL (for email links)
FRONTEND_URL=https://yourdomain.com

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
